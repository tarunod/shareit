{
  "name": "socket",
  "version": "1.0.3",
  "description": "Local network messaging and transfer workspace",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "version:bump": "node scripts/bump-version.js",
    "version:bump:dry": "node scripts/bump-version.js --dry-run",
    "prebuild": "node scripts/bump-version.js",
    "build": "electron-builder build --win --publish never",
    "predist": "node scripts/verify-release-env.js && node scripts/bump-version.js",
    "dist": "electron-builder build --win --publish always"
  },
  "build": {
    "appId": "com.socket.app",
    "productName": "Socket",
    "win": {
      "icon": "img/socket_icon.png",
      "target": "nsis",
      "publish": [
        {
          "provider": "github",
          "owner": "tarunod",
          "repo": "shareit"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "tarunod",
      "repo": "shareit"
    }
  },
  "keywords": [
    "lan",
    "chat",
    "sync",
    "files",
    "sharing"
  ],
  "author": "Nitish",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "gsap": "^3.12.5",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  }
}
